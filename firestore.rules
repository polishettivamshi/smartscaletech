rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'polishettivamshi123@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // Professional Profiles
    match /professionals/{professionalId} {
      function isValidProfessional(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.role is string && data.role.size() > 0 && data.role.size() <= 100
          && data.location is string && data.location.size() > 0 && data.location.size() <= 100
          && data.status in ['review', 'active']
          && data.userId is string;
      }

      allow read: if true;
      allow create: if isSignedIn() 
        && isValidId(professionalId)
        && isValidProfessional(incoming())
        && incoming().status == 'review'
        && incoming().isPaid == false
        && incoming().userId == request.auth.uid
        && (incoming().userId == professionalId || isAdmin())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      
      allow update: if (isOwner(existing().userId) || isAdmin())
        && isValidProfessional(incoming())
        && incoming().updatedAt == request.time
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (isAdmin() || (
            (incoming().status == existing().status || (existing().status == 'review' && incoming().status == 'active' && incoming().isPaid == true))
            && (incoming().isPaid == existing().isPaid || (existing().isPaid == false && incoming().isPaid == true))
          ));
      
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // User Data
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid
          && data.email is string;
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
    }
  }
}
